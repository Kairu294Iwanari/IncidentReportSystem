@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_IncidentLayout.cshtml";
}

<style>
    body {
        margin: 0;
        background: #f8fafc;
        font-family: sans-serif;
    }

    .wrap {
        display: flex;
        min-height: 100vh;
    }

    .left {
        flex: 1;
        background: linear-gradient(135deg, #0f172a, #1e3a5f, #c2410c);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px;
    }

        .left h1 {
            color: #fff;
            font-size: 40px;
            font-weight: 800;
            text-align: center;
            margin: 0 0 14px;
        }

        .left p {
            color: rgba(255,255,255,0.65);
            font-size: 15px;
            text-align: center;
            margin: 0;
        }

    .right {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px;
    }

    .box {
        width: 100%;
        max-width: 400px;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 28px;
    }

    .logo-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .logo-name {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

        .logo-name span {
            color: #3b82f6;
        }

    h2 {
        font-size: 22px;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 4px;
    }

    .sub {
        font-size: 13px;
        color: #64748b;
        margin: 0 0 22px;
    }

    .btn-blue {
        display: block;
        width: 100%;
        text-align: center;
        background: #2563eb;
        color: #fff !important;
        font-size: 15px;
        font-weight: 600;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
        margin-bottom: 18px;
        text-decoration: none;
        border: none;
        font-family: inherit;
        box-sizing: border-box;
    } 

    .bottom {
        text-align: center;
        font-size: 13px;
        color: #6b7280;
    }

        .bottom a {
            color: #2563eb;
            font-weight: 600;
            text-decoration: none;
        }

    @@media (max-width: 768px) {
        .left {
            display: none;
        }

        .right {
            padding: 32px 24px;
        }
    }
</style>

<div class="wrap" ng-init="initialRun()">

    <div class="left">
        <h1>Barangay Incident Reporting System</h1>
        <p>Report and track incidents in your community.</p>
    </div>

    <div class="right">
        <div class="box">

            <div class="logo">
                <div class="logo-icon">
                    <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                </div>
                <div class="logo-name">Barangay <span>IRS</span></div>
            </div>

            <h2>Welcome back</h2>
            <p class="sub">Sign in to your account to continue</p>

            <form class="col s12">

                <div class="row">
                    <div class="input-field col s12">
                        <i class="material-icons prefix">person_pin</i>
                        <input id="loginUsername" type="text" class="validate" ng-model="loginUsername" placeholder="Enter your username">
                        <label for="loginUsername">Username</label>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12" style="position:relative;">
                        <i class="material-icons prefix">lock</i>
                        <input id="loginPassword" type="password" class="validate" ng-model="loginPassword" maxlength="16" placeholder="Enter your password">
                        <label for="loginPassword">Password</label>
                        <i class="material-icons" id="toggleLoginPwd" style="position:absolute; right:10px; top:12px; cursor:pointer; color:#757575;">visibility</i>
                    </div>
                </div>

                <div class="row" style="margin-bottom: 0;">
                    <div class="col s12">
                        <button type="button" class="btn-blue" ng-click="checkLogin()">Sign In</button>
                    </div>
                </div>

                <div class="bottom">
                    Don't have an account?&nbsp;<a href="/Incident/RegistrationPage">Create one here</a>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    document.getElementById('toggleLoginPwd').addEventListener('click', function () {
        var input = document.getElementById('loginPassword');
        if (input.type === 'password') {
            input.type = 'text';
            this.textContent = 'visibility_off';
        } else {
            input.type = 'password';
            this.textContent = 'visibility';
        }
    });
</script>