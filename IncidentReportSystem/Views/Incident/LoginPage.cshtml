@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_IncidentLayout.cshtml";
}

<style>
    body {
        margin: 0;
        background: #f8fafc;
        font-family: sans-serif;
    }

    .wrap {
        display: flex;
        min-height: 100vh;
    }

    .left {
        flex: 1;
        background: linear-gradient(135deg, #0f172a, #1e3a5f, #2563eb);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px;
    }

        .left h1 {
            color: #fff;
            font-size: 40px;
            font-weight: 800;
            text-align: center;
            margin: 0 0 14px;
        }

        .left p {
            color: rgba(255,255,255,0.65);
            font-size: 15px;
            text-align: center;
            margin: 0;
        }

    .right {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
        overflow-y: auto;
    }

    .box {
        width: 100%;
        max-width: 400px;
        padding: 10px 0;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .logo-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .logo-name {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

        .logo-name span {
            color: #3b82f6;
        }

    h2 {
        font-size: 22px;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 4px;
    }

    .sub {
        font-size: 13px;
        color: #64748b;
        margin: 0 0 16px;
    }

    .btn-blue {
        display: block;
        width: 100%;
        text-align: center;
        color: #fff !important;
        font-size: 15px;
        font-weight: 600;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
        text-decoration: none;
        border: none;
        box-sizing: border-box;
        transition: background-color 0.2s ease;
        background-color: #2563eb;
        margin-top: 20px;
        margin-bottom: 14px;
    }

        .btn-blue:hover {
            background-color: #1e3a8a !important;
        }

    .bottom {
        text-align: center;
        font-size: 13px;
        color: #6b7280;
        margin-top: 4px;
    }

        .bottom a {
            color: #2563eb;
            font-weight: 600;
            text-decoration: none;
        }

    @@media (max-width: 768px) {
        .left {
            display: none;
        }

        .right {
            padding: 28px 20px;
        }
    }
</style>

<div class="wrap" ng-init="initialRun()">
    <div class="left">
        <h1>Welcome back.</h1>
        <p>Sign in to access your barangay incident dashboard.</p>
    </div>
    <div class="right">
        <div class="box">
            <div class="logo">
                <div class="logo-icon">
                    <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
                    </svg>
                </div>
                <div class="logo-name">Barangay <span>IRS</span></div>
            </div>

            <h2>Sign in to your account</h2>
            <p class="sub">Enter your credentials below</p>

            <form class="col s12">
                <div class="row">
                    <div class="input-field col s12">
                        <i class="material-icons prefix">person_pin</i>
                        <input id="icon_uname" type="text" ng-model="loginUsername" placeholder="Username">
                        <label for="icon_uname">Username</label>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12" style="position:relative;">
                        <i class="material-icons prefix">lock</i>
                        <input id="icon_pass" type="password" ng-model="loginPassword" placeholder="Password">
                        <label for="icon_pass">Password</label>
                        <i class="material-icons" id="togglePass" style="position:absolute; right:10px; top:12px; cursor:pointer; color:#757575;">visibility</i>
                    </div>
                </div>

                <button type="button" class="btn-blue" ng-click="loginFunc()">Sign In</button>

                <div class="bottom">
                    Don't have an account yet?&nbsp;<a href="/Incident/RegistrationPage">Register here</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById('togglePass').addEventListener('click', function () {
        var input = document.getElementById('icon_pass');
        if (input.type === 'password') { input.type = 'text'; this.textContent = 'visibility_off'; }
        else { input.type = 'password'; this.textContent = 'visibility'; }
    });
</script>