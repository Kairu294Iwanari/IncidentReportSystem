@{
    ViewBag.Title = "Official Dashboard";
    Layout = "~/Views/Shared/_IncidentLayout.cshtml";
}
<style>
    body {
        margin: 0;
        background: #f1f5f9;
        font-family: sans-serif;
    }

    .nav {
        background: #0f172a;
        height: 60px;
        padding: 0 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .nav-logo {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .nav-title {
        font-size: 15px;
        font-weight: 700;
        color: #fff;
    }

        .nav-title span {
            color: #60a5fa;
        }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .nav-user {
        font-size: 13px;
        color: #94a3b8;
    }

        .nav-user strong {
            color: #e2e8f0;
        }

    .badge {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        background: #dcfce7;
        color: #15803d;
        display: inline-block;
    }

    .badge-status {
        background: #e0e7ff;
        color: #4338ca;
    }

    .btn-logout {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #ef4444;
        color: #fff;
        border: none;
        padding: 7px 14px;
        border-radius: 7px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-logout:hover {
            background: #dc2626;
        }

    .page {
        padding: 28px;
        padding-bottom: 80px;
    }

    .banner {
        background: linear-gradient(135deg, #15803d, #22c55e);
        border-radius: 12px;
        padding: 24px 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

        .banner h2 {
            color: #fff;
            font-size: 20px;
            font-weight: 700;
            margin: 0 0 4px;
        }

        .banner p {
            color: rgba(255,255,255,0.8);
            font-size: 13px;
            margin: 0;
        }

    .banner-icon {
        width: 54px;
        height: 54px;
        background: rgba(255,255,255,0.15);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .label {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin: 0 0 12px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 16px;
        margin-bottom: 30px;
    }

    .card {
        background: #fff;
        border-radius: 10px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        display: block;
        transition: transform 0.15s, box-shadow 0.15s;
    }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        }

        .card h3 {
            font-size: 14px;
            font-weight: 700;
            color: #64748b;
            margin: 0 0 10px;
            text-transform: uppercase;
        }

        .card h2 {
            font-size: 32px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }
</style>

<div ng-init="initialRun()">
    <div class="nav">
        <div class="nav-left">
            <div class="nav-logo">
                <svg width="16" height="16" fill="none" stroke="white" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                </svg>
            </div>
            <div class="nav-title">Barangay <span>IRS</span></div>
        </div>
        <div class="nav-right">
            <div class="nav-user">Hello, <strong>{{currentUser.FirstName}} {{currentUser.LastName}}</strong></div>
            <span class="badge">Barangay Official</span>
            <button class="btn-logout" ng-click="logoutFunc()"><i class="material-icons" style="font-size: 16px; margin-right: 4px;">exit_to_app</i>Logout</button>
        </div>
    </div>

    <div class="page">
        <div class="banner">
            <div><h2>Welcome, {{currentUser.FirstName}}!</h2><p>Review and update incident reports.</p></div>
        </div>

        <p class="label">Incident Status Overview</p>
        <div class="grid">
            <div class="card" ng-repeat="card in cardData">
                <h3>{{ card.StatusDesc }}</h3><h2>{{ card.StatusCount }}</h2>
            </div>
        </div>

        <div class="row">
            <div class="col s12" ng-class="{'m8': selectedIncident}">
                <p class="label">All Incident Reports</p>
                <div style="background:#fff; border-radius:10px; border: 1px solid #e2e8f0; overflow:hidden;">
                    <table style="width:100%; border-collapse: collapse;">
                        <thead style="background:#f8fafc; border-bottom:1px solid #e2e8f0; font-size:12px; color:#64748b; text-transform:uppercase;"><tr><th style="padding:14px;">Report Info</th><th style="padding:14px;">Category</th><th style="padding:14px;">Status</th><th style="padding:14px;">Action</th></tr></thead>
                        <tbody>
                            <tr ng-repeat="data in dashboardDataArray | orderBy:'-incident.IncidentID'" style="border-bottom:1px solid #f1f5f9;">
                                <td style="padding:14px;"><strong style="color: #0f172a;">{{ data.incident.Title }}</strong><br><span style="font-size:12px; color:#64748b;">{{ data.incident.CreatedAt | date:'MMM dd, yyyy - hh:mm a' }}</span></td>
                                <td style="padding:14px; font-size:14px;">{{ data.category.CategoryName }}</td>
                                <td style="padding:14px;"><span class="badge badge-status">{{ data.status.StatusName }}</span></td>
                                <td style="padding:14px;"><button style="background:#3b82f6; color:#fff; border:none; padding:6px 12px; border-radius:4px; cursor:pointer;" ng-click="viewIncident(data)">Review</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col s12 m4" ng-show="selectedIncident">
                <p class="label">Review & Update Status</p>
                <div style="background: #fff; border-radius: 10px; padding: 25px; border: 1px solid #e2e8f0;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 15px;">
                        <h3 style="margin: 0; font-size: 18px;">Incident Details</h3>
                        <i class="material-icons" style="cursor: pointer; color: #ef4444;" ng-click="closeIncidentView()">close</i>
                    </div>
                    <p style="margin: 8px 0; font-size: 14px;"><strong>Title:</strong> {{selectedIncident.incident.Title}}</p>
                    <p style="margin: 8px 0; font-size: 14px;"><strong>Reported By:</strong> {{selectedIncident.user.FirstName}} {{selectedIncident.user.LastName}}</p>
                    <p style="margin: 8px 0; font-size: 14px;"><strong>Phone:</strong> {{selectedIncident.user.PhoneNumber}}</p>
                    <div style="background: #f8fafc; padding: 12px; border-radius: 6px; margin: 12px 0;"><strong>Description:</strong><br /><span>{{selectedIncident.incident.Description}}</span></div>

                    <label style="font-weight: 600; margin-bottom: 8px; display: block;">Update Status</label>
                    <select class="browser-default" ng-model="selectedIncident.incident.StatusID" style="display: block; width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; margin-bottom: 15px;">
                        <option ng-repeat="s in statusList" value="{{s.StatusID}}">{{s.StatusName}}</option>
                    </select>
                    <button type="button" style="background: #16a34a; color: #fff; border: none; padding: 12px; border-radius: 6px; width: 100%; cursor: pointer;" ng-click="updateStatusFunc()">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
</div>