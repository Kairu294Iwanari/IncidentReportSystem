@{
    ViewBag.Title = "Resident Dashboard";
    Layout = "~/Views/Shared/_IncidentLayout.cshtml";
}
<style>
    body {
        margin: 0;
        background: #f1f5f9;
        font-family: sans-serif;
    }

    .nav {
        background: #0f172a;
        height: 60px;
        padding: 0 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .nav-logo {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .nav-title {
        font-size: 15px;
        font-weight: 700;
        color: #fff;
    }

        .nav-title span {
            color: #60a5fa;
        }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .nav-user {
        font-size: 13px;
        color: #94a3b8;
    }

        .nav-user strong {
            color: #e2e8f0;
        }

    .badge {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        background: #dcfce7;
        color: #15803d;
        display: inline-block;
    }

    .badge-status {
        background: #e0e7ff;
        color: #4338ca;
    }

    .btn-logout {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #ef4444;
        color: #fff;
        border: none;
        padding: 7px 14px;
        border-radius: 7px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-logout:hover {
            background: #dc2626;
        }

    .page {
        padding: 28px;
        padding-bottom: 80px;
    }

    .banner {
        background: linear-gradient(135deg, #0284c7, #38bdf8);
        border-radius: 12px;
        padding: 24px 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

        .banner h2 {
            color: #fff;
            font-size: 20px;
            font-weight: 700;
            margin: 0 0 4px;
        }

        .banner p {
            color: rgba(255,255,255,0.8);
            font-size: 13px;
            margin: 0;
        }

    .banner-icon {
        width: 54px;
        height: 54px;
        background: rgba(255,255,255,0.15);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .label {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin: 0 0 12px;
    }
</style>

<div ng-init="initialRun()">
    <div class="nav">
        <div class="nav-left">
            <div class="nav-logo">
                <svg width="16" height="16" fill="none" stroke="white" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                </svg>
            </div>
            <div class="nav-title">Barangay <span>IRS</span></div>
        </div>
        <div class="nav-right">
            <div class="nav-user">Hello, <strong>{{currentUser.FirstName}} {{currentUser.LastName}}</strong></div>
            <span class="badge" style="background:#e0f2fe; color:#0369a1;">Resident</span>
            <button class="btn-logout" ng-click="logoutFunc()"><i class="material-icons" style="font-size: 16px; margin-right: 4px;">exit_to_app</i>Logout</button>
        </div>
    </div>

    <div class="page">
        <div class="banner">
            <div><h2>Welcome, {{currentUser.FirstName}}!</h2><p>Report incidents directly to officials.</p></div>
        </div>

        <button style="background:{{showReportForm ? '#ef4444' : '#2563eb'}}; color:#fff; border:none; padding:12px 24px; border-radius:6px; cursor:pointer; margin-bottom:20px; display:inline-flex; align-items:center; gap:8px;" ng-click="toggleReportForm()">
            <i class="material-icons" style="font-size: 18px;">{{ showReportForm ? 'close' : 'add_circle_outline' }}</i>
            {{ showReportForm ? 'Cancel Report' : 'File a New Report' }}
        </button>

        <div class="row" ng-show="showReportForm">
            <div class="col s12 m6">
                <div style="background:#fff; border-radius:10px; padding:25px; border:1px solid #e2e8f0; margin-bottom:20px;">
                    <h3 style="margin-top:0; color:#0f172a; font-weight:700;">Submit New Report</h3>
                    <form>
                        <label>Incident Title</label><input type="text" ng-model="incidentTitle" style="width:100%; padding:10px; border:1px solid #ced4da; border-radius:4px; margin-bottom:15px; box-sizing:border-box;">
                        <label>Location</label><input type="text" ng-model="incidentLocation" style="width:100%; padding:10px; border:1px solid #ced4da; border-radius:4px; margin-bottom:15px; box-sizing:border-box;">
                        <label>Category</label><select class="browser-default" ng-model="incidentCategory" ng-options="c.CategoryID as c.CategoryName for c in categoriesList" style="width:100%; padding:10px; border:1px solid #ced4da; border-radius:4px; margin-bottom:15px;"><option value="" disabled>Select Category</option></select>
                        <label>Priority</label><select class="browser-default" ng-model="incidentPriority" ng-options="p.PriorityID as p.PriorityName for p in prioritiesList" style="width:100%; padding:10px; border:1px solid #ced4da; border-radius:4px; margin-bottom:15px;"><option value="" disabled>Select Priority</option></select>
                        <label>Description</label><textarea ng-model="incidentDesc" style="width:100%; padding:10px; border:1px solid #ced4da; border-radius:4px; height:100px; margin-bottom:15px; box-sizing:border-box;"></textarea>
                        <button type="button" style="background:#16a34a; color:#fff; border:none; padding:10px 20px; border-radius:6px; width:100%; cursor:pointer; font-weight:600;" ng-click="submitReportFunc()">Submit Report</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col s12">
                <p class="label">Your Submitted Reports</p>
                <div style="background:#fff; border-radius:10px; border:1px solid #e2e8f0; overflow:hidden;">
                    <table style="width:100%; border-collapse:collapse;">
                        <thead style="background:#f8fafc; border-bottom:1px solid #e2e8f0; font-size:12px; color:#64748b; text-transform:uppercase;"><tr><th style="padding:14px;">Incident Title</th><th style="padding:14px;">Category</th><th style="padding:14px;">Status</th><th style="padding:14px;">Date Reported</th></tr></thead>
                        <tbody>
                            <tr ng-repeat="data in dashboardDataArray" ng-if="data.incident.ResidentID == currentUser.UserID" style="border-bottom:1px solid #f1f5f9;">
                                <td style="padding:14px; font-weight:600; color:#0f172a;">{{ data.incident.Title }}</td>
                                <td style="padding:14px; font-size:14px;">{{ data.category.CategoryName }}</td>
                                <td style="padding:14px;"><span class="badge badge-status">{{ data.status.StatusName }}</span></td>
                                <td style="padding:14px; font-size:14px; color:#334155;">{{ data.incident.CreatedAt | date:'MMM dd, yyyy - hh:mm a' }}</td>
                            </tr>
                            <tr ng-if="(dashboardDataArray | filter:{incident: {ResidentID: currentUser.UserID}}).length == 0">
                                <td colspan="4" style="text-align:center; padding:30px; color:#94a3b8; font-size:14px;">You have not submitted any reports.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>